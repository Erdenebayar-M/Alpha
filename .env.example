# Database (Postgres on port 5433)
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5433/mongolian_app?schema=public"

# Server
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=generate_with__node_-e_"console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS (frontend dev server URL)
CORS_ORIGIN=http://localhost:5173

# Content pipeline — AI providers
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...

# Seeding guard (leave empty; set to "true" only for intentional prod reseeds)
# ALLOW_PROD_SEED=
