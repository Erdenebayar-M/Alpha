                  "pm.test('Status is 201 or 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('Token returned', () => pm.expect(json.data.token).to.be.a('string'));",
