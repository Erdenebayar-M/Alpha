{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node10",
    "types": ["node", "jest"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["prisma/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
